{
  "expo": {
    "name": "IPTV Player",
    "slug": "tv",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "iptv-player",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.gerc.tv",
      "minSdkVersion": 26
    },
    "extra": {
      "eas": {
        "projectId": "9ae792f1-8935-44b7-ad20-b00ee52fb696"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-document-picker"
    ]
  }
}
